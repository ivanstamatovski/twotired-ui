# Copy this to .env and fill in your values
# Add .env to .gitignore — never commit real keys

VITE_SUPABASE_URL=https://ujvfwzcjgxupvtiwllhw.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Supabase Edge Function secrets (set via: supabase secrets set KEY=value) ──
# These are NOT exposed to the frontend — edge function only.

ANTHROPIC_API_KEY=your_anthropic_api_key_here        # Claude narrative layer
GEMINI_API_KEY=your_gemini_api_key_here              # Gemini geospatial + Google Maps grounding
ORS_API_KEY=your_openrouteservice_api_key_here       # Road geometry snapping
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here # Internal Supabase access

# ── Getting your Gemini API key ───────────────────────────────────────────────
# 1. Go to https://aistudio.google.com/app/apikey
# 2. Create a key — make sure your project has Google Maps Platform enabled
#    for the Maps grounding feature to work (https://mapsplatform.google.com)
# 3. Set it in Supabase: supabase secrets set GEMINI_API_KEY=your_key
