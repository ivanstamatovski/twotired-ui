{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/", "has": [{ "type": "query", "key": "add" }], "destination": "/index.html" },
    { "source": "/", "destination": "/home.html" },
    { "source": "/app", "destination": "/index.html" }
  ]
}
