# Copy this file to `keystore.properties` (which is gitignored) and fill in real
# values AFTER you generate the upload keystore. See CLAUDE.md "Publishing to Google Play".
#
#   keytool -genkey -v -keystore ~/twotired-upload.jks \
#           -keyalg RSA -keysize 2048 -validity 10000 -alias twotired
#
# storeFile    = absolute path to the .jks you generated
# storePassword/keyPassword = the password(s) you set during keytool (record in your password manager)
# keyAlias     = the -alias you passed to keytool (twotired)
#
# NEVER commit the real keystore.properties or the .jks — both are gitignored.

storeFile=/Users/ivanstamatovski/twotired-upload.jks
storePassword=CHANGEME
keyAlias=twotired
keyPassword=CHANGEME
